@model IReadOnlyList<Component>
@{
    ViewData["Title"] = "Components";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Component catalog</h1>
        <p class="text-secondary small mb-0">Manage <code>Data/buildcores.json</code>. Writes use a temp file and atomic replace.</p>
    </div>
    <a class="btn btn-primary rounded-pill px-4" asp-area="Admin" asp-controller="Catalog" asp-action="Create">
        <i class="bi bi-plus-lg me-1"></i> Create component
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 small">
            <thead class="table-light">
                <tr>
                    <th>Type</th>
                    <th>Id</th>
                    <th>Name</th>
                    <th class="d-none d-md-table-cell">Manufacturer</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><span class="badge text-bg-dark text-uppercase">@c.Type</span></td>
                        <td class="fw-semibold">@c.Id</td>
                        <td>@c.Name</td>
                        <td class="d-none d-md-table-cell text-secondary">@c.Manufacturer</td>
                        <td class="text-end">@c.Price.ToString("C2")</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Catalog" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                            <form asp-area="Admin" asp-controller="Catalog" asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this component permanently?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
