@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h3 fw-bold mb-4">Dashboard</h1>

<div class="row g-3 g-xl-4 mb-4">
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 rounded-4">
            <div class="card-body p-4">
                <div class="small text-secondary text-uppercase fw-semibold mb-1">Total users</div>
                <div class="display-5 fw-bold text-primary">@Model.TotalUsers</div>
                <div class="small text-muted mt-2">Registered Identity accounts.</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm h-100 rounded-4">
            <div class="card-body p-4">
                <div class="small text-secondary text-uppercase fw-semibold mb-1">Saved builds</div>
                <div class="display-5 fw-bold text-success">@Model.TotalSavedBuilds</div>
                <div class="small text-muted mt-2">All snapshots in <code class="small">savedbuilds.json</code>.</div>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm h-100 rounded-4 bg-dark text-white">
            <div class="card-body p-4 d-flex flex-column justify-content-center">
                <div class="fw-semibold mb-2"><i class="bi bi-shield-lock me-2"></i>Security</div>
                <p class="small mb-0 opacity-75">This area requires the <strong>Admin</strong> role. Assign roles via your Identity store or SQLite tooling.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <h2 class="h5 fw-bold mb-1">Most popular components</h2>
                <p class="small text-secondary mb-0">Frequency across saved builds (by slot).</p>
            </div>
            <div class="card-body p-4">
                @if (!Model.PopularComponents.Any())
                {
                    <div class="alert alert-light border mb-0 small">No usage data yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle small mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Slot</th>
                                    <th>Part</th>
                                    <th class="text-end">Uses</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.PopularComponents)
                                {
                                    <tr>
                                        <td><span class="badge text-bg-secondary">@row.Slot</span></td>
                                        <td>
                                            <div class="fw-semibold">@row.Name</div>
                                            <div class="text-muted">@row.Manufacturer · Id @row.ComponentId</div>
                                        </td>
                                        <td class="text-end fw-bold">@row.UsageCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <h2 class="h5 fw-bold mb-1">Common compatibility signals</h2>
                <p class="small text-secondary mb-0">Aggregated from running the compatibility engine on each saved build.</p>
            </div>
            <div class="card-body p-4">
                @if (!Model.CommonCompatibilityIssues.Any())
                {
                    <div class="alert alert-light border mb-0 small">No saved builds to analyze.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush rounded-3 border">
                        @foreach (var issue in Model.CommonCompatibilityIssues)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start gap-2 px-3 py-3">
                                <div class="small @(issue.IsWarning ? "text-warning-emphasis" : "text-danger-emphasis")">
                                    @if (issue.IsWarning)
                                    {
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-octagon me-1"></i>
                                    }
                                    @issue.Message
                                </div>
                                <span class="badge @(issue.IsWarning ? "text-bg-warning" : "text-bg-danger") rounded-pill">@issue.Count</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
