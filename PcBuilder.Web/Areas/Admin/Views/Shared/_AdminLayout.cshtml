<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body bg-light">
    <header class="admin-topbar border-bottom bg-white shadow-sm">
        <div class="container-fluid py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="badge text-bg-dark rounded-pill px-3">Admin</span>
                <span class="text-secondary small">PcBuilder.Web</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="small text-secondary d-none d-md-inline">@User.Identity?.Name</span>
                <a class="btn btn-sm btn-outline-secondary" asp-area="" asp-controller="Home" asp-action="Index">Site home</a>
                <a class="btn btn-sm btn-outline-primary" asp-area="" asp-controller="Builder" asp-action="Index">Builder</a>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row flex-lg-nowrap">
            <nav class="admin-sidebar col-lg-2 border-end bg-white py-4 px-0 shadow-sm min-vh-100-lg">
                <div class="px-3 mb-3 small text-uppercase text-secondary fw-semibold">Menu</div>
                <ul class="nav flex-column gap-1 px-2">
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active bg-dark text-white" : "text-dark")"
                           asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link rounded-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Catalog" ? "active bg-dark text-white" : "text-dark")"
                           asp-area="Admin" asp-controller="Catalog" asp-action="Index">
                            <i class="bi bi-box-seam me-2"></i> Components
                        </a>
                    </li>
                </ul>
            </nav>
            <main class="admin-main col-lg-10 py-4 px-3 px-lg-5">
                @if (TempData["AdminMessage"] is string adminMsg && !string.IsNullOrWhiteSpace(adminMsg))
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                        @adminMsg
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
