@{
    ViewData["Title"] = "Access denied";
}

<div class="py-5">
    <div class="mx-auto" style="max-width: 520px;">
        <h1 class="h3 fw-bold mb-3">Access denied</h1>
        <p class="text-secondary mb-4">
            You do not have permission to view this page. Admin pages require the <strong>Admin</strong> role.
        </p>
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go home</a>
        <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Login">Sign in as another user</a>
    </div>
</div>
