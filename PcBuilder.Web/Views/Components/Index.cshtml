@model ComponentCatalogViewModel
@{
    ViewData["Title"] ??= "Catalog";
}

<div class="components-catalog-page py-4 py-lg-5">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-lg-between gap-3 mb-4">
        <div>
            <h1 class="h2 fw-bold mb-2">Component catalog</h1>
            <p class="text-secondary mb-0 col-lg-10">
                Browse the repository with server-side filters. Use the <a asp-controller="Builder" asp-action="Index">builder</a> for compatibility validation.
            </p>
        </div>
        <div class="text-lg-end">
            <span class="badge rounded-pill text-bg-primary fs-6 px-3 py-2">@Model.Components.Count.ToString("N0") shown</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 rounded-4">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-controller="Components" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-12 col-md-6 col-xl-4">
                    <label class="form-label small fw-semibold mb-1" for="cat-search">Search name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="search" class="form-control" id="cat-search" name="search" value="@Model.Search"
                               placeholder="Filter by name…" autocomplete="off" />
                    </div>
                </div>
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small fw-semibold mb-1" for="cat-type">Type</label>
                    <select class="form-select" id="cat-type" name="type">
                        <option value="">All types</option>
                        @foreach (var t in Model.AvailableTypes)
                        {
                            if (string.Equals(Model.Type, t, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@t" selected>@t</option>
                            }
                            else
                            {
                                <option value="@t">@t</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small fw-semibold mb-1" for="cat-mfr">Manufacturer</label>
                    <select class="form-select" id="cat-mfr" name="manufacturer">
                        <option value="">All manufacturers</option>
                        @foreach (var m in Model.AvailableManufacturers)
                        {
                            if (string.Equals(Model.Manufacturer, m, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@m" selected>@m</option>
                            }
                            else
                            {
                                <option value="@m">@m</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small fw-semibold mb-1" for="cat-socket">Socket</label>
                    <select class="form-select" id="cat-socket" name="socket">
                        <option value="">Any socket</option>
                        @foreach (var s in Model.AvailableSockets)
                        {
                            if (string.Equals(Model.Socket, s, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label small fw-semibold mb-1" for="cat-sort">Sort by</label>
                    <select class="form-select" id="cat-sort" name="sortBy">
                        @{
                            var sortChoices = new (string Value, string Label)[]
                            {
                                ("name", "Name (A–Z)"),
                                ("price_asc", "Price · Low to high"),
                                ("price_desc", "Price · High to low"),
                                ("manufacturer", "Manufacturer (A–Z)")
                            };
                        }
                        @foreach (var o in sortChoices)
                        {
                            if (string.Equals(Model.SortBy, o.Value, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@o.Value" selected>@o.Label</option>
                            }
                            else
                            {
                                <option value="@o.Value">@o.Label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-xl-12 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-dark"><i class="bi bi-funnel me-1"></i>Apply</button>
                    <a class="btn btn-outline-secondary" asp-controller="Components" asp-action="Index">Reset</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Components.Any())
    {
        <div class="alert alert-light border rounded-4 shadow-sm">
            <strong>No components match your filters.</strong>
            <span class="d-block small text-secondary mt-1">Try clearing search or widening type and socket filters.</span>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model.Components)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm component-catalog-card overflow-hidden rounded-4">
                        @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="component-image w-100" alt="" />
                        }
                        else
                        {
                            <div class="bg-body-secondary d-flex align-items-center justify-content-center" style="height: 170px;">
                                <i class="bi bi-box-seam fs-1 text-secondary"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <span class="badge text-bg-secondary text-capitalize">@item.Type</span>
                            </div>
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">@item.Manufacturer</div>
                            <h2 class="h6 fw-bold mb-2">@item.Name</h2>
                            <div class="fw-semibold text-primary mb-3">@item.Price.ToString("C2")</div>
                            <div class="mt-auto">
                                <partial name="_ComponentCardSpecs" model="item" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
