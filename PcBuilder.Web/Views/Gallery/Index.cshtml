@model PcBuilder.Web.Models.GalleryIndexViewModel
@{
    ViewData["Title"] = "Public gallery";
    var sortOptions = new (string Value, string Label)[]
    {
        ("newest", "Newest first"),
        ("oldest", "Oldest first"),
        ("price_asc", "Price · Low to high"),
        ("price_desc", "Price · High to low"),
        ("compat_desc", "Compatibility · High"),
        ("compat_asc", "Compatibility · Low"),
        ("fps_desc", "FPS · High"),
        ("fps_asc", "FPS · Low"),
        ("name_asc", "Name · A–Z"),
        ("name_desc", "Name · Z–A")
    };
}

<div class="gallery-page py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-lg-between gap-3 mb-4">
        <div>
            <h1 class="h2 fw-bold mb-2">Public build gallery</h1>
            <p class="text-secondary mb-0">
                Explore configurations shared by the community. Open any build in the configurator to tweak parts.
            </p>
        </div>
        <a class="btn btn-primary" asp-controller="Builder" asp-action="Index">
            <i class="bi bi-tools me-1"></i> Start building
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-controller="Gallery" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-12 col-md-4 col-lg-4">
                    <label class="form-label small fw-semibold mb-1" for="gallery-search">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="search"
                               class="form-control"
                               id="gallery-search"
                               name="q"
                               value="@Model.SearchQuery"
                               placeholder="Build name, creator, category…"
                               autocomplete="off" />
                    </div>
                </div>
                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label small fw-semibold mb-1" for="gallery-category">Category</label>
                    <select class="form-select" id="gallery-category" name="category">
                        @if (string.IsNullOrEmpty(Model.Category))
                        {
                            <option value="" selected>All categories</option>
                        }
                        else
                        {
                            <option value="">All categories</option>
                        }
                        @foreach (var cat in Model.Categories)
                        {
                            if (string.Equals(Model.Category, cat, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@cat" selected>@cat</option>
                            }
                            else
                            {
                                <option value="@cat">@cat</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label small fw-semibold mb-1" for="gallery-sort">Sort</label>
                    <select class="form-select" id="gallery-sort" name="sort">
                        @foreach (var o in sortOptions)
                        {
                            if (string.Equals(Model.Sort, o.Value, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@o.Value" selected>@o.Label</option>
                            }
                            else
                            {
                                <option value="@o.Value">@o.Label</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1">Apply</button>
                    <a class="btn btn-outline-secondary" asp-controller="Gallery" asp-action="Index" title="Reset filters">Reset</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Builds.Any())
    {
        <div class="alert alert-light border rounded-3 shadow-sm">
            <strong>No public builds match your filters.</strong>
            <span class="d-block small text-secondary mt-1">Save a build from the builder with “Share publicly in gallery” checked, or widen your search.</span>
        </div>
    }
    else
    {
        <p class="small text-secondary mb-3">Showing <strong>@Model.Builds.Count</strong> build@(Model.Builds.Count == 1 ? "" : "s")</p>
        <div class="row g-4">
            @foreach (var build in Model.Builds)
            {
                var fpsLabel = build.EstimatedFps1080p > 0 ? $"{build.EstimatedFps1080p} FPS (1080p est.)" : "N/A";
                var creator = string.IsNullOrWhiteSpace(build.CreatorUserName) ? "Community member" : build.CreatorUserName;
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm gallery-build-card rounded-4 overflow-hidden">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h2 class="h5 fw-bold mb-0">@build.DisplayName</h2>
                                <span class="badge text-bg-primary flex-shrink-0">@build.BuildCategory</span>
                            </div>
                            <div class="small text-secondary mb-3">
                                <i class="bi bi-person-circle me-1"></i>@creator
                            </div>
                            <dl class="row small mb-0 flex-grow-1">
                                <dt class="col-6 text-secondary">Total price</dt>
                                <dd class="col-6 text-end fw-semibold">@build.TotalPrice.ToString("C2")</dd>
                                <dt class="col-6 text-secondary">Compatibility</dt>
                                <dd class="col-6 text-end fw-semibold">@build.CompatibilityPercentage%</dd>
                                <dt class="col-6 text-secondary">Est. FPS</dt>
                                <dd class="col-6 text-end fw-semibold">@fpsLabel</dd>
                                <dt class="col-6 text-secondary">Saved</dt>
                                <dd class="col-6 text-end">@build.CreatedAtUtc.ToLocalTime().ToString("g")</dd>
                            </dl>
                            <div class="mt-4 d-grid">
                                <a class="btn btn-primary"
                                   asp-controller="Builder"
                                   asp-action="Index"
                                   asp-route-cpuId="@build.CpuId"
                                   asp-route-motherboardId="@build.MotherboardId"
                                   asp-route-ramId="@build.RamId"
                                   asp-route-gpuId="@build.GpuId"
                                   asp-route-psuId="@build.PsuId"
                                   asp-route-caseId="@build.CaseId"
                                   asp-route-coolerId="@build.CoolerId">
                                    <i class="bi bi-box-arrow-up-right me-1"></i> Open in builder
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
