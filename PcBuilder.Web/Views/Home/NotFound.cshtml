@{
    ViewData["Title"] = "Page not found";
}

<div class="py-5">
    <div class="empty-state rounded-4 p-5 text-center text-secondary mx-auto" style="max-width: 720px;">
        <div class="empty-state-icon mb-3"><i class="bi bi-exclamation-triangle"></i></div>
        <h1 class="display-6 fw-bold text-body mb-3">404 - Page not found</h1>
        <p class="lead mb-4">The page you are looking for does not exist or may have been moved.</p>
        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go home</a>
            <a class="btn btn-outline-secondary" asp-controller="Builder" asp-action="Index">Open builder</a>
        </div>
    </div>
</div>
