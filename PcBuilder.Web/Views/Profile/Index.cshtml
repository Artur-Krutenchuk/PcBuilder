@model PcBuilder.Web.Models.ProfileIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Profile";
    var registeredDisplay = Model.RegisteredAtUtc.HasValue
        ? Model.RegisteredAtUtc.Value.ToLocalTime().ToString("MMMM d, yyyy")
        : "—";
    var chartPayload = JsonSerializer.Serialize(Model.ManufacturerChartData.Select(m => new { name = m.Name, count = m.Count }));
}

<div class="profile-dashboard py-3 py-md-4">
    <div class="row g-4 mb-2 align-items-center">
        <div class="col-12 col-lg-8">
            <h1 class="h2 fw-bold mb-1">Your profile</h1>
            <p class="text-secondary mb-0">
                Signed in as <span class="fw-semibold text-dark">@Model.UserName</span>
                @if (!string.IsNullOrWhiteSpace(Model.Email) && !string.Equals(Model.Email, Model.UserName, StringComparison.OrdinalIgnoreCase))
                {
                    <span class="text-secondary">(@Model.Email)</span>
                }
            </p>
        </div>
        <div class="col-12 col-lg-4 text-lg-end">
            <a class="btn btn-primary" asp-controller="Builder" asp-action="Index">Go to builder</a>
        </div>
    </div>

    <div class="row g-3 g-md-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body">
                    <div class="text-secondary small text-uppercase fw-semibold mb-1">Saved builds</div>
                    <div class="display-6 fw-bold text-primary">@Model.SavedBuildCount</div>
                    <div class="small text-muted mt-2">Total configurations saved to your account.</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body">
                    <div class="text-secondary small text-uppercase fw-semibold mb-1">Registration date</div>
                    <div class="fs-4 fw-bold">@registeredDisplay</div>
                    <div class="small text-muted mt-2">When this account was created (local time).</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body">
                    <div class="text-secondary small text-uppercase fw-semibold mb-1">Favorite category</div>
                    <div class="fs-4 fw-bold">@Model.FavoriteCategory</div>
                    <div class="small text-muted mt-2">Most common build category in your saves.</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 stat-card">
                <div class="card-body">
                    <div class="text-secondary small text-uppercase fw-semibold mb-1">Average build budget</div>
                    <div class="fs-4 fw-bold">@Model.AverageBuildBudget.ToString("C2")</div>
                    <div class="small text-muted mt-2">Mean total price across saved builds.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-md-4">
        <div class="col-12 col-xl-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0 pt-3 px-3">
                    <h2 class="h5 fw-semibold mb-0">Favorite manufacturers</h2>
                    <p class="small text-secondary mb-0 mt-1">Part manufacturers appearing most often across your saved builds.</p>
                </div>
                <div class="card-body">
                    @if (!Model.ManufacturerChartData.Any())
                    {
                        <div class="alert alert-light border mb-0">Save a few builds to see manufacturer trends.</div>
                    }
                    else
                    {
                        <div class="chart-wrap position-relative w-100" style="min-height: 300px;">
                            <canvas id="manufacturer-chart" aria-label="Favorite manufacturers chart"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0 pt-3 px-3 d-flex align-items-center justify-content-between">
                    <div>
                        <h2 class="h5 fw-semibold mb-0">Recent saved builds</h2>
                        <p class="small text-secondary mb-0 mt-1">Newest first.</p>
                    </div>
                </div>
                <div class="card-body pt-2">
                    @if (!Model.RecentSavedBuilds.Any())
                    {
                        <div class="alert alert-light border mb-0">No saved builds yet. Use the builder to create one.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush recent-builds-list">
                            @foreach (var build in Model.RecentSavedBuilds)
                            {
                                <div class="list-group-item px-0 py-3 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                        <span class="badge text-bg-primary">@build.BuildCategory</span>
                                        <span class="badge text-bg-dark">@build.CompatibilityPercentage%</span>
                                    </div>
                                    <div class="small text-secondary">
                                        <span class="fw-semibold text-dark">@build.TotalPrice.ToString("C2")</span>
                                        · @build.EstimatedWattage W est.
                                    </div>
                                    <div class="small text-muted mt-1">
                                        @build.CreatedAtUtc.ToLocalTime().ToString("g")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    @if (Model.ManufacturerChartData.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                const data = @Html.Raw(chartPayload);
                const labels = data.map(x => x.name);
                const values = data.map(x => x.count);
                const palette = [
                    "#0d6efd", "#6610f2", "#6f42c1", "#d63384", "#dc3545",
                    "#fd7e14", "#ffc107", "#198754", "#20c997", "#0dcaf0",
                    "#6c757d", "#212529"
                ];
                const colors = labels.map((_, i) => palette[i % palette.length]);

                const canvas = document.getElementById("manufacturer-chart");
                if (!canvas || typeof Chart === "undefined") {
                    return;
                }

                const ctx = canvas.getContext("2d");
                new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels,
                        datasets: [{
                            label: "Parts selected",
                            data: values,
                            backgroundColor: colors,
                            borderRadius: 6,
                            maxBarThickness: 42
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: (ctx) => ` ${ctx.parsed.y} selections`
                                }
                            }
                        },
                        scales: {
                            x: {
                                ticks: { autoSkip: false, maxRotation: 45, minRotation: 0 }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            }
                        }
                    }
                });
            })();
        </script>
    }
}
