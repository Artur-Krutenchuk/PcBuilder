@model ProfileDashboardViewModel
@{
    ViewData["Title"] ??= "Profile";
    var lastBuildDisplay = Model.LastBuildCreatedAt.HasValue
        ? Model.LastBuildCreatedAt.Value.ToLocalTime().ToString("g")
        : "—";
}

<div class="profile-dashboard py-4 py-lg-5">
    <div class="row g-4 mb-4 align-items-stretch">
        <div class="col-12 col-lg-5">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width: 3.5rem; height: 3.5rem;">
                            <i class="bi bi-person-fill fs-3"></i>
                        </div>
                        <div>
                            <h1 class="h4 fw-bold mb-0">@Model.UserName</h1>
                            @if (!string.IsNullOrWhiteSpace(Model.Email))
                            {
                                <div class="small text-secondary">@Model.Email</div>
                            }
                        </div>
                    </div>
                    <p class="text-secondary small mb-4 mb-lg-0">
                        Your dashboard summarizes saved builds from this account. Open the builder or My Builds to manage configurations.
                    </p>
                    <div class="d-flex flex-wrap gap-2 mt-lg-4">
                        <a class="btn btn-primary" asp-controller="Builder" asp-action="Index">
                            <i class="bi bi-tools me-1"></i>Go to Builder
                        </a>
                        <a class="btn btn-outline-primary" asp-controller="MyBuilds" asp-action="Index">
                            <i class="bi bi-collection me-1"></i>My Builds
                        </a>
                        <a class="btn btn-outline-secondary" asp-controller="PopularBuilds" asp-action="Index">
                            <i class="bi bi-stars me-1"></i>Popular Builds
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-7">
            <div class="row g-3 h-100">
                <div class="col-6 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Saved builds</div>
                            <div class="fs-2 fw-bold text-primary">@Model.SavedBuildsCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Avg. price</div>
                            <div class="fs-5 fw-bold">@Model.AverageBuildPrice.ToString("C2")</div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Favorite category</div>
                            <div class="fs-6 fw-bold text-truncate" title="@Model.FavoriteBuildCategory">@Model.FavoriteBuildCategory</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Best compatibility</div>
                            <div class="fs-2 fw-bold text-success">@Model.BestCompatibilityPercentage%</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Avg. compatibility</div>
                            <div class="fs-2 fw-bold">@Model.AverageCompatibilityPercentage%</div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="card border-0 shadow-sm h-100 rounded-4 bg-body-tertiary">
                        <div class="card-body p-3 text-center">
                            <div class="small text-secondary text-uppercase fw-semibold mb-1">Last build saved</div>
                            <div class="small fw-semibold">@lastBuildDisplay</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex flex-column flex-sm-row align-items-sm-center justify-content-sm-between gap-2">
            <div>
                <h2 class="h5 fw-bold mb-0">Recent saved builds</h2>
                <p class="small text-secondary mb-0 mt-1">Newest first (up to eight).</p>
            </div>
            <a class="btn btn-sm btn-outline-primary" asp-controller="MyBuilds" asp-action="Index">View all</a>
        </div>
        <div class="card-body p-4">
            @if (!Model.RecentSavedBuilds.Any())
            {
                <div class="alert alert-light border mb-0">No saved builds yet. Use the builder to create your first configuration.</div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var build in Model.RecentSavedBuilds)
                    {
                        <div class="list-group-item px-0 py-3 border-bottom">
                            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-1">
                                <span class="fw-semibold">@build.DisplayName</span>
                                <div class="d-flex flex-wrap gap-2">
                                    <span class="badge text-bg-primary text-capitalize">@build.BuildCategory</span>
                                    <span class="badge text-bg-dark">@build.CompatibilityPercentage%</span>
                                </div>
                            </div>
                            <div class="small text-secondary">
                                <span class="fw-semibold text-dark">@build.TotalPrice.ToString("C2")</span>
                                · @build.EstimatedWattage W est.
                            </div>
                            <div class="small text-muted mt-1">
                                @build.CreatedAtUtc.ToLocalTime().ToString("g")
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
