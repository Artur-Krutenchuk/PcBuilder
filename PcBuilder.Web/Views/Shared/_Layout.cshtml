<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PcBuilder.Web</title>
    <script>
        (function () {
            var theme = localStorage.getItem("pcbuilder-theme") || "light";
            document.documentElement.setAttribute("data-bs-theme", theme === "dark" ? "dark" : "light");
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PcBuilder.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3 app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">PcBuilder.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Builder" asp-action="Index">Builder</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Gallery" asp-action="Index">Gallery</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Compare" asp-action="Index">Compare</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PopularBuilds" asp-action="Index">Popular Builds</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Components" asp-action="Index">Catalog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Statistics" asp-action="Index">Statistics</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="MyBuilds" asp-action="Index">My Builds</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">Profile</a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-secondary">Hello, <strong>@(User.Identity?.Name ?? "User")</strong></span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                    <button id="theme-toggle" type="button" class="btn btn-sm btn-outline-secondary ms-sm-2" aria-label="Toggle dark mode">
                        <i class="bi bi-moon-stars me-1"></i><span>Dark</span>
                    </button>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-2">
            <div>&copy; 2026 - PcBuilder.Web</div>
            <div class="d-flex flex-wrap gap-3">
                <a asp-area="" asp-controller="Home" asp-action="About">About</a>
                <a href="https://github.com/placeholder/pcbuilder" target="_blank" rel="noopener">GitHub</a>
                <a asp-area="" asp-controller="Home" asp-action="About" asp-fragment="technologies">Technologies used</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var button = document.getElementById("theme-toggle");
            if (!button) {
                return;
            }

            function syncButton(theme) {
                var isDark = theme === "dark";
                button.innerHTML = isDark
                    ? '<i class="bi bi-sun me-1"></i><span>Light</span>'
                    : '<i class="bi bi-moon-stars me-1"></i><span>Dark</span>';
            }

            var current = document.documentElement.getAttribute("data-bs-theme") || "light";
            syncButton(current);
            button.addEventListener("click", function () {
                var next = document.documentElement.getAttribute("data-bs-theme") === "dark" ? "light" : "dark";
                document.documentElement.setAttribute("data-bs-theme", next);
                localStorage.setItem("pcbuilder-theme", next);
                syncButton(next);
            });
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
